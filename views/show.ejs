<% layout("/layouts/boilerplate") %>
<body>
    <h3 class="heading mt-4 ">Listing Details</h3>
    <div class="row">
        <div class="card show-card col-12 offset-1.5" >
            <img src="<%= listing.image %>" class="card-img-top img-show" alt="listing_image">
            <div class="card-body col-12">
              <h5 class="card-title"><%=listing.title%></h5>
              <p class="card-text"><%=listing.description%></p>
            </div>
            <ul class="list-group list-group-flush">
              <li class="list-group-item">&#8377 <%=listing.price.toLocaleString("en-IN")%></li>
              <li class="list-group-item"><%=listing.location%></li>
              <li class="list-group-item"><%=listing.country%></li>
            </ul>
            <div class="card-body btns">
              <a href="/listings/<%=listing._id%>/edit" class="card-link btn btn-dark add">Edit</a>
              <form method="post" action="/listings/<%=listing._id%>?_method=DELETE">
                <button class="btn btn-dark offset-3">Delete</button>
              </form>
            </div>
          </div>
    </div>
    
</body>
