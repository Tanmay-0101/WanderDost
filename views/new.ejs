<% layout("/layouts/boilerplate") %>
<body>
    <div class="row">
        <div class="col-12">
        <br>    
        <h3>Create a New Listing</h3>
            <br>
            <form method="post" action="/listings" novalidate class="needs-validation">
                <div class="mb-3">
                    <label for="title" class="form-label"><b>Title</b></label>
                    <input type="text" class="form-control" name="listing[title]" placeholder="Add a catchy title" required>
                    <div class="valid-feedback">Title looks good!</div>
                </div>
        
                <div class="mb-3">
                    <label for="description" class="form-label"><b>Description</b></label>
                    <textarea type="text" class="form-control" name="listing[description]" placeholder="Describe about the place" required></textarea> 
                    <div class="valid-feedback">Description looks good!</div>
                </div>    
        
                <div class="mb-3">
                    <label for="image" class="form-label"><b>Image Link</b></label>
                    <input type="text" class="form-control" name="listing[image]" placeholder="Enter image URL/link">
                </div>        
        
                <div class="row">
                    <div class="mb-3 col-md-6">
                        <label for="location" class="form-label"><b>Location</b></label>
                        <input type="text" class="form-control" name="listing[location]" placeholder="New Delhi" required>
                        <div class="invalid-feedback">Location is invalid</div>
                    </div>
            
                    <div class="mb-3 col-md-6">
                        <label for="country" class="form-label"><b>Country</b></label>
                        <input type="text" class="form-control" name="listing[country]" placeholder="India" required>
                        <div class="invalid-feedback">Country is invalid</div>
                    </div>    
                </div>

                <div class="mb-3">
                    <label for="price" class="form-label"><b>Price</b></label>
                    <input type="number" class="form-control" name="listing[price]" placeholder="1200" required>
                    <div class="invalid-feedback">Enter valid price</div>
                </div>
                <br><br>
                <button class="btn btn-dark add">Add</button>
                <br><br>
            </form>
        </div>
    
    </div>   
</body>
