<% layout("/layouts/boilerplate") %>
<body>
    <div class="row">
        <div class="col-12">
            <br>
            <h3>Edit Listing</h3>
            <br>
            <form method="post" action="/listings/<%=edtListing._id%>?_method=PUT" novalidate class="needs-validation">
                <div class="mb-3">
                    <label for="title" class="form-label"><b>Title</b></label>
                    <input type="text" class="form-control" name="listing[title]" value="<%=edtListing.title%>" required>
                    <div class="valid-feedback">Title looks good!</div>
                </div>    
        
                <div class="mb-3">
                    <label for="description" class="form-label"><b>Description</b></label>
                    <textarea type="text" class="form-control" name="listing[description]" required><%=edtListing.description%></textarea>
                    <div class="valid-feedback">Description looks good!</div> 
                </div>

                <div class="mb-3">
                    <label for="image" class="form-label"><b>Image Link/URL</b></label>
                    <input type="text" class="form-control" name="listing[image]" value="<%=edtListing.image%>" required>
                    <div class="invalid-feedback">Please provide valid image link</div>
                </div>

                <div class="row">
                    <div class="mb-3 col-md-6">
                        <label for="location" class="form-label"><b>Location</b></label>
                        <input type="text" class="form-control" name="listing[location]" value="<%=edtListing.location%>" required>
                        <div class="invalid-feedback">Location is invalid</div>
                    </div>
    
                    <div class="mb-3 col-md-6">
                        <label for="country" class="form-label"><b>Country</b></label>
                        <input type="text" class="form-control" name="listing[country]" value="<%=edtListing.country%>" required>
                        <div class="invalid-feedback">Country is invalid</div>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="price" class="form-label"><b>Price</b></label>
                    <input type="number" class="form-control" name="listing[price]" value="<%=edtListing.price%>" required>
                    <div class="invalid-feedback">Please enter valid price</div>
                </div>    
                <br><br>
                <button class="btn btn-dark add">Edit</button>
                <br><br>
            </form>
        </div>
    </div>
    
</body>
