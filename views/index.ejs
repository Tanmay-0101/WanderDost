<% layout("/layouts/boilerplate") %>
<body>
    <h3>All Listings</h3>
    <div class="row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
        <%for(let list of allListings){%>
            <a href="/listings/<%=list._id%>">
                <div class="card col" style="width: 20rem;">
                    <img src="<%=list.image%>" class="card-img-top" style="height: 20rem" alt="listing-img">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                    <p class="card-text">
                        <b><%=list.title%></b><br>
                        &#8377 <%=list.price.toLocaleString("en-IN")%>/night
                    </p>
                    </div>
                </div>
            </a>
        <%}%>  
    </div>
</body>
